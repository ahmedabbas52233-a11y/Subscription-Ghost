{
  "name": "subscription-ghost-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev":          "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build":        "tsc",
    "start":        "node dist/server.js",
    "typecheck":    "tsc --noEmit",
    "test":         "jest --runInBand --detectOpenHandles --forceExit",
    "test:watch":   "jest --watch",
    "test:coverage":"jest --coverage"
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "bullmq":             "^5.7.5",
    "cors":               "^2.8.5",
    "dotenv":             "^16.4.5",
    "express":            "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet":             "^7.1.0",
    "ioredis":            "^5.3.2",
    "jsonwebtoken":       "^9.0.2",
    "mongoose":           "^8.4.1",
    "morgan":             "^1.10.0",
    "node-cron":          "^3.0.3",
    "nodemailer":         "^6.9.13",
    "zod":                "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs":     "^2.4.6",
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/jest":         "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan":       "^1.9.9",
    "@types/node":         "^20.14.2",
    "@types/node-cron":    "^3.0.11",
    "@types/nodemailer":   "^6.4.15",
    "@types/supertest":    "^6.0.2",
    "jest":                "^29.7.0",
    "mongodb-memory-server":"^9.3.0",
    "supertest":           "^7.0.0",
    "ts-jest":             "^29.1.4",
    "ts-node-dev":         "^2.0.0",
    "typescript":          "^5.4.5"
  }
}
